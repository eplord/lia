# Environment Configuration

# ==============================================
# APPLICATION SETTINGS
# ==============================================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
APP_NAME=Lia

# ==============================================
# DATABASE
# ==============================================
# PostgreSQL (recommended)
DATABASE_URL=postgresql://lia:password@localhost:5432/lia

# MongoDB (alternative)
# DATABASE_URL=mongodb://localhost:27017/lia

# ==============================================
# REDIS (CACHE & SESSIONS)
# ==============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ==============================================
# AUTHENTICATION & SECURITY
# ==============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-very-long-random-secret-key
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-this-to-another-very-long-random-secret-key
SESSION_MAX_AGE=604800000

# CORS Settings
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ==============================================
# STORAGE
# ==============================================
# Options: local, s3
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# S3-Compatible Storage (MinIO, AWS S3, DigitalOcean Spaces, etc.)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lia
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PATH_STYLE=true

# ==============================================
# SEARCH ENGINE
# ==============================================
# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# Elasticsearch (alternative)
# ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_INDEX=lia

# ==============================================
# AI FEATURES
# ==============================================
# Enable AI features
ENABLE_AI_FEATURES=true

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# Local AI (Ollama)
ENABLE_LOCAL_AI=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# AI Features Configuration
AI_AUTO_TAGGING=true
AI_AUTO_SUMMARIZATION=true
AI_TAG_COUNT=5

# ==============================================
# FEATURES
# ==============================================
# OCR (Optical Character Recognition)
ENABLE_OCR=true
OCR_LANGUAGE=eng

# Full-page archival
ENABLE_PAGE_ARCHIVAL=true
ARCHIVAL_FORMAT=html

# Video archival
ENABLE_VIDEO_ARCHIVAL=true
MAX_VIDEO_SIZE=500M

# Wayback Machine integration
ENABLE_WAYBACK_MACHINE=false

# Screenshot capture
ENABLE_SCREENSHOTS=true
SCREENSHOT_QUALITY=90

# PDF annotation
ENABLE_PDF_ANNOTATION=true

# RSS feed import
ENABLE_RSS_IMPORT=true

# Browser sync (Floccus)
ENABLE_BROWSER_SYNC=true

# ==============================================
# RATE LIMITING
# ==============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# API rate limits
API_RATE_LIMIT_MAX=1000
API_RATE_LIMIT_WINDOW_MS=3600000

# ==============================================
# EMAIL (OPTIONAL)
# ==============================================
# SMTP Configuration
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Lia
SMTP_FROM_EMAIL=noreply@lia.dev

# ==============================================
# SSO / OAUTH (OPTIONAL)
# ==============================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3000/auth/microsoft/callback

# ==============================================
# LOGGING
# ==============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=logs/lia.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7

# ==============================================
# MONITORING (OPTIONAL)
# ==============================================
# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Google Analytics
GOOGLE_ANALYTICS_ID=

# ==============================================
# QUEUE / BACKGROUND JOBS
# ==============================================
QUEUE_DRIVER=bull
QUEUE_REDIS_URL=redis://localhost:6379

# Job concurrency
QUEUE_CONCURRENCY=5

# ==============================================
# FRONTEND SETTINGS
# ==============================================
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=Lia
VITE_ENABLE_PWA=true

# ==============================================
# DEVELOPMENT ONLY
# ==============================================
# Enable debug mode
DEBUG=false

# Enable API documentation
ENABLE_API_DOCS=true

# Seed database with sample data
DB_SEED_ENABLED=false

# ==============================================
# ADVANCED
# ==============================================
# Max file upload size
MAX_FILE_SIZE=100M

# Max request body size
MAX_REQUEST_SIZE=10M

# Session store
SESSION_STORE=redis

# Timezone
TZ=UTC

# Number of worker processes (auto = CPU count)
WORKERS=auto

# Graceful shutdown timeout (ms)
SHUTDOWN_TIMEOUT=10000
